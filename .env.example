APP_NAME=ai-powered-retail-analytics-inventory-agent
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_WORKERS=4
LOG_LEVEL=DEBUG

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_BIGQUERY_DATASET=retail_analytics
GCP_SERVICE_ACCOUNT_KEY_PATH=  # Leave empty for ADC
GCP_CLOUD_RUN_SERVICE_NAME=retail-agent

# BigQuery Tables
BQ_PRODUCTS_TABLE=products
BQ_INVENTORY_TABLE=inventory
BQ_SALES_TABLE=sales
BQ_FORECASTS_TABLE=forecasts
BQ_REPORTS_TABLE=reports
BQ_CUSTOMER_INSIGHTS_TABLE=customer_insights

# Agent Configuration
AGENT_MAX_ITERATIONS=15
AGENT_VERBOSE=true
AGENT_TIMEOUT_SECONDS=120

# Forecasting
FORECAST_HORIZON_DAYS=30
FORECAST_CONFIDENCE_INTERVAL=0.95
FORECAST_MIN_HISTORICAL_DAYS=90

# Reporting
REPORT_SCHEDULE_CRON=0 8 * * *
REPORT_OUTPUT_FORMAT=pdf

# Redis (for caching, optional)
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]